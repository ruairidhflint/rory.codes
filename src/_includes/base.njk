<!DOCTYPE html>
<html lang="en" prefix="og: http://ogp.me/ns#">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    {% include "./_header.njk" %}
</head>
<body>
    {% block main %}
  {% endblock %}
      <script>
        // Reveal any scheduled post whose publish date has now arrived.
        // Future posts are rendered with `hidden` at build time; this lets
        // them appear on their date without needing a site rebuild.
        document.querySelectorAll("li[data-publish]").forEach(function (el) {
          if (new Date(el.getAttribute("data-publish")) <= new Date()) {
            el.hidden = false;
          }
        });

        const toggleButton = document.getElementById("toggleDarkMode");
        if (toggleButton) {
          toggleButton.addEventListener("click", function() {
            if (isDarkMode()) {
              localStorage.theme = 'light'
              document.documentElement.classList.remove('dark')
            } else {
              localStorage.theme = 'dark'
              document.documentElement.classList.add('dark')
            }
          });
        }
    </script>
</body>
</html>